<Window x:Class="ServicoInteligenteGeografico.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ServicoInteligenteGeografico"
        mc:Ignorable="d"
        Title="Serviço inteligente Greográfico" Height="589" Width="800">

    <!-- Estilos e recursos da janela -->
    <Window.Resources>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" >
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Efeito Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Layout principal dividido em duas colunas -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            
            <!-- StackPanel para busca de locais e resultados -->
            <StackPanel Grid.Column="0" Margin="10">
                <TextBlock Text="Buscar Localização:" FontWeight="Bold" FontSize="14" Margin="0,0,0,5" />

                <UniformGrid Columns="2">
                    <Button Style="{StaticResource ButtonStyle}" Content="Buscar" FontWeight="Bold" Margin="0,10,5,10" Height="38" Command="{Binding BuscarCommand}" />
                    <Button Style="{StaticResource ButtonStyle}" Content="Limpar" FontWeight="Bold" Margin="5,10,0,10" Height="38" Command="{Binding LimparCommand}" />
                </UniformGrid>
                <!-- Lista de locais encontrados -->
                <TextBlock Text="Locais Encontrados:" FontWeight="Bold" FontSize="12" Margin="0,5" />
                <ListBox ItemsSource="{Binding Dados}" Height="250">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Id}" FontWeight="Bold" Foreground="DarkBlue" Margin="0,0,15,0" VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Logradouro}" FontWeight="Bold" FontSize="14"/>
                                            <TextBlock Text=", N°: " FontWeight="Bold" Margin="5,0,0,0"/>
                                            <TextBlock Text="{Binding Numero}" FontWeight="Bold"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="Bairro: " Foreground="Gray"/>
                                            <TextBlock Text="{Binding Bairro}" Margin="0,0,10,0"/>
                                            <TextBlock Text="CEP: " Foreground="Gray"/>
                                            <TextBlock Text="{Binding CEP}" Margin="0,0,10,0"/>
                                            <TextBlock Text="Lat: " FontSize="11" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Latitude}" FontSize="11" Foreground="Gray" Margin="0,0,10,0"/>
                                            <TextBlock Text="Long: " FontSize="11" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Longitude}" FontSize="11" Foreground="Gray"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <!-- Filtro por Região -->
            <StackPanel Grid.Column="1" Margin="10">
                <TextBlock Text="Filtro por Região:" FontWeight="Bold" FontSize="14" Margin="0,0,0,5" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Width="100" SelectedValuePath="Content" SelectedValue="{Binding TipoFiltro}">
                        <ComboBoxItem Content="Bairro" IsSelected="True" />
                        <ComboBoxItem Content="Logradouro" />
                        <ComboBoxItem Content="CEP" />
                    </ComboBox>
                    <TextBox Grid.Column="1" Margin="5,0,0,0" Padding="6" Text="{Binding FiltroTexto, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <!-- Gerar Relátorios e verificar historico -->
                <TextBlock Text="Geração de Relatórios:" FontWeight="Bold" FontSize="14" Margin="0,15,0,5" />
                <UniformGrid Columns="2">
                    <Button Style="{StaticResource ButtonStyle}" Content="Gerar PDF" Margin="0,0,-190,0" Height="36" FontWeight="Bold" Command="{Binding GerarPdfCommand}" />
                </UniformGrid>

                <!-- Calculo de  Distância entre pontos-->
                <Border Background="#F9F9F9" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Cálculo de Distância Entre Pontos:" FontSize="14" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,10"/>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="2">
                                <TextBlock Text="Lat Origem (A):" FontSize="10"/>
                                <TextBox Padding="6" Text="{Binding LatitudeOrigem, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="2">
                                <TextBlock Text="Long Origem (A):" FontSize="10"/>
                                <TextBox Padding="6" Text="{Binding LongitudeOrigem, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="2">
                                <TextBlock Text="Lat Destino (B):" FontSize="10"/>
                                <TextBox Padding="6" Text="{Binding Latitude, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="2">
                                <TextBlock Text="Long Destino (B):" FontSize="10"/>
                                <TextBox Padding="6" Text="{Binding Longitude, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>

                        <Border Background="#E8F5E9" Margin="0,10" Padding="5" CornerRadius="3">
                            <TextBlock Text="{Binding ResultadoFormatado}" 
                                       Foreground="Green" 
                                       HorizontalAlignment="Center" 
                                       FontSize="14" 
                                       FontWeight="Bold" />
                        </Border>

                        <Button Content="Calcular" 
                                Command="{Binding CalcularCommand}" 
                                Height="30" 
                                FontWeight="Bold"
                                Background="#007ACC" 
                                Foreground="White"
                                Cursor="Hand"/> 
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>

        <!-- Tabela de Ranking -->
        <GroupBox Grid.Row="1" Header="Ranking de Locais" Margin="10" FontWeight="Bold" FontSize="14">
            <DataGrid ItemsSource="{Binding Resultados}" 
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      BorderThickness="1"
                      BorderBrush="#DDD">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Logradouro" Binding="{Binding Logradouro}" Width="2*"/>
                    <DataGridTextColumn Header="Nº" Binding="{Binding Numero}" Width="50"/>
                    <DataGridTextColumn Header="Bairro" Binding="{Binding Bairro}" Width="1*"/>
                    <DataGridTextColumn Header="CEP" Binding="{Binding Cep}" Width="80"/>
                    <DataGridTextColumn Header="Lat" Binding="{Binding Latitude, StringFormat={}{0:F4}}" Width="80"/>
                    <DataGridTextColumn Header="Long" Binding="{Binding Longitude, StringFormat={}{0:F4}}" Width="80"/>
                    <DataGridTextColumn Header="Data/Hora" Binding="{Binding Timestamp}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>
